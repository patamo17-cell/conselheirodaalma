{
  "entities": {
    "Versiculo": {
      "title": "Versiculo",
      "description": "Um versículo bíblico com explicação e metadados",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "codigo": { "type": "string" },
        "categoria": { "type": "string" },
        "sentimentos": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "versiculo": { "type": "string" },
        "referencia": { "type": "string" },
        "explicacao": { "type": "string" },
        "youtubeMusicUrl": { "type": "string" }
      },
      "required": ["id", "codigo", "categoria", "versiculo", "referencia", "explicacao"]
    },
    "User": {
      "title": "User",
      "description": "Dados do usuário do aplicativo",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/conselheirodaalma/{versiculoId}": {
      "schema": "Versiculo",
      "description": "Coleção de versículos bíblicos para o app Conselheiro da Alma"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Coleção de usuários do sistema"
    }
  }
}
